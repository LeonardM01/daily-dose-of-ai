// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id             String          @id @default(cuid())
    name           String?
    email          String?         @unique
    emailVerified  DateTime?
    image          String?
    isAdmin        Boolean         @default(false)
    accounts       Account[]
    sessions       Session[]
    ownerSettings  OwnerSettings?
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model OwnerSettings {
    id                         String   @id @default(cuid())
    userId                     String   @unique
    user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    googleAiApiKeyEncrypted    String?  @db.Text
    gcpServiceAccountEncrypted String?  @db.Text
    timezone                   String   @default("UTC")
    preferredRunHour           Int      @default(6)
    updatedAt                  DateTime @updatedAt
}

model SourceFeed {
    id        String          @id @default(cuid())
    name      String
    url       String          @unique
    category  String?
    enabled   Boolean         @default(true)
    createdAt DateTime        @default(now())
    articles  SourceArticle[]
}

model SourceArticle {
    id          String           @id @default(cuid())
    feedId      String?
    feed        SourceFeed?      @relation(fields: [feedId], references: [id], onDelete: SetNull)
    url         String           @unique
    title       String
    sourceName  String
    publishedAt DateTime?
    excerpt     String?          @db.Text
    contentHash String?
    rawContent  String?          @db.Text
    createdAt   DateTime         @default(now())
    briefings   BriefingSource[]

    @@index([publishedAt])
    @@index([createdAt])
}

model DailyBriefing {
    id              String          @id @default(cuid())
    briefingDate    DateTime
    title           String
    /// Final SSML passed to TTS (same payload used for audio synthesis).
    script          String          @db.Text
    /// Humanized plain text for display; wording matches what listeners hear.
    transcript      String?         @db.Text
    audioUrl        String?
    status          BriefingStatus  @default(PENDING)
    durationSeconds Int?
    errorMessage    String?         @db.Text
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    sources         BriefingSource[]
    jobRuns         JobRun[]

    @@unique([briefingDate])
    @@index([briefingDate])
}

enum BriefingStatus {
    PENDING
    GENERATING
    COMPLETED
    FAILED
}

model BriefingSource {
    id         String        @id @default(cuid())
    briefingId String
    briefing   DailyBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)
    articleId  String
    article    SourceArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

    @@unique([briefingId, articleId])
}

model JobRun {
    id                 String              @id @default(cuid())
    briefingDate       DateTime
    status             JobRunStatus
    startedAt          DateTime            @default(now())
    finishedAt         DateTime?
    error              String?             @db.Text
    idempotencyKey     String              @unique
    tokensInput        Int?
    tokensOutput       Int?
    ttsCharacters      Int?
    briefingId         String?
    briefing           DailyBriefing?      @relation(fields: [briefingId], references: [id], onDelete: SetNull)
    generationAttempts GenerationAttempt[]

    @@index([briefingDate])
}

enum JobRunStatus {
    STARTED
    SUCCESS
    FAILED
}

model GenerationAttempt {
    id         String                  @id @default(cuid())
    jobRunId   String
    jobRun     JobRun                  @relation(fields: [jobRunId], references: [id], onDelete: Cascade)
    stage      GenerationAttemptStage
    status     GenerationAttemptStatus
    prompt     String?                 @db.Text
    response   String?                 @db.Text
    error      String?                 @db.Text
    metadata   Json?
    createdAt  DateTime                @default(now())
    updatedAt  DateTime                @updatedAt

    @@index([jobRunId, stage, createdAt])
}

enum GenerationAttemptStage {
    RANKING
    SCRIPT_TRANSCRIPT
    SCRIPT_HUMANIZE
    SCRIPT_SSML
}

enum GenerationAttemptStatus {
    SUCCESS
    FAILED
}

/// Prevents duplicate concurrent daily generation for the same calendar day (UTC).
model JobLock {
    briefingDate DateTime @id
    runId        String
    lockedAt     DateTime @default(now())
}
