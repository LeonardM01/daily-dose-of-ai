# Copy to .env and fill in values.

# Runtime secrets for generation
GOOGLE_AI_API_KEY=""
# Put the full service-account JSON on one line in .env, or as a platform secret in Vercel.
# Example:
# GOOGLE_TTS_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}'
GOOGLE_TTS_SERVICE_ACCOUNT_JSON=""

# Optional: Cloudflare R2 for MP3 storage (recommended for production)
R2_BUCKET=""
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""

# Prisma — matches docker-compose Postgres service
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dailydose"

# Optional legacy encryption key (only needed if you later re-enable DB-stored secrets)
APP_ENCRYPTION_KEY=""

# Vercel Cron: send Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

PRODUCT_HUNT_TOKEN=""
PRODUCT_HUNT_CLIENT_ID=""
PRODUCT_HUNT_CLIENT_SECRET=""

# Optional: override Chirp 3 HD voice.
# Example en-US options include: en-US-Chirp3-HD-Charon, en-US-Chirp3-HD-Despina, en-US-Chirp3-HD-Achernar
# TTS_VOICE_NAME="en-US-Chirp3-HD-Despina"
